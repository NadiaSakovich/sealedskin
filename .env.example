# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored; never commit real keys.

# Which AI backend to use. Supported: gemini
AI_PROVIDER=gemini

# Default model for the selected provider. The results screen has a temporary
# picker to switch between gemini-3.1-flash-lite and gemini-3.5-flash; this is
# the fallback when none is requested. Use a Gemini 3.x model — they support
# Grounding with Google Search together with structured JSON output.
AI_MODEL=gemini-3.1-flash-lite

# Google Gemini API key — create one at https://aistudio.google.com/apikey.
# This same key enables Grounding with Google Search; no extra setup needed.
GEMINI_API_KEY=

# --- Firebase ---
# Public web/client config — from Firebase console → Project settings → your Web
# app → SDK setup ("firebaseConfig"). Safe to expose; these are identifiers.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin service-account — from Project settings → Service accounts → Generate new
# private key (downloads a JSON). SECRET: only in .env.local, never commit.
# FIREBASE_PRIVATE_KEY goes on ONE line in quotes, keeping the literal \n escapes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
