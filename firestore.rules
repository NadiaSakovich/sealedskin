// SealedSkin Firestore security rules.
//
// All writes happen server-side through /api/users using the Firebase Admin SDK,
// which bypasses these rules. So we deny ALL direct client access — no browser
// can read or write Firestore directly. This is the safest default.
//
// To apply: Firebase console → Firestore Database → Rules → paste this → Publish.
//
// If a future feature reads a user's own data straight from the browser, relax
// the read rule to something like:
//   match /users/{uid}/{document=**} {
//     allow read: if request.auth != null && request.auth.uid == uid;
//   }
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
